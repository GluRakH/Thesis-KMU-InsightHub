{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://insighthub.local/schemas/templates.schema.json",
  "title": "InsightHub Templates",
  "type": "object",
  "required": ["schema_version", "template_version", "templates"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "template_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/template" }
    }
  },
  "$defs": {
    "dimensionId": {
      "type": "string",
      "enum": ["BI_D1", "BI_D2", "BI_D3", "PA_D1", "PA_D2", "PA_D3"]
    },
    "category": {
      "type": "string",
      "enum": ["governance", "technical", "organizational", "data"]
    },
    "kpi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "baseline_definition", "target", "measurement", "frequency"],
      "properties": {
        "name": { "type": "string", "minLength": 3 },
        "baseline_definition": { "type": "string", "minLength": 5 },
        "baseline_value": { "type": ["number", "string", "null"] },
        "target": { "type": "string", "minLength": 2 },
        "measurement": { "type": "string", "minLength": 5 },
        "frequency": { "type": "string", "enum": ["weekly", "monthly", "quarterly"] },
        "source_system": { "type": ["string", "null"] },
        "owner_role": { "type": ["string", "null"] }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template_id", "title", "category", "applies_to", "goal", "deliverables", "kpi", "impact", "effort"],
      "properties": {
        "template_id": { "type": "string", "pattern": "^[A-Z0-9_]{6,64}$" },
        "title": { "type": "string", "minLength": 5 },
        "category": { "$ref": "#/$defs/category" },
        "applies_to": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dimensions"],
          "properties": {
            "dimensions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/dimensionId" },
              "uniqueItems": true
            }
          }
        },
        "goal": { "type": "string", "minLength": 10 },
        "diagnosis_rules": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "trigger_items_preferred": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "deficit_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "deliverables": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "string", "minLength": 5 }
        },
        "kpi": { "$ref": "#/$defs/kpi" },
        "impact": { "type": "integer", "minimum": 1, "maximum": 5 },
        "effort": { "type": "integer", "minimum": 1, "maximum": 5 },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    }
  }
}